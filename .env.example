# ESG Controversy Detection System — Environment Variables
# Copy this file to .env and fill in your API keys.
# All keys are OPTIONAL — the system runs in synthetic mode without them.

# NewsAPI (https://newsapi.org/)
NEWSAPI_KEY=

# The Guardian Open Platform (https://open-platform.theguardian.com/)
GUARDIAN_API_KEY=

# SEC EDGAR User-Agent (required format: "Company/App contact@email.com")
SEC_USER_AGENT=ESGControversySystem admin@example.com
